<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Invitation</title>
  <style>
      * { box-sizing: border-box; }

      body {
          font-family: "DejaVu Sans", Arial, sans-serif;
          font-size: 11px;
          margin: 15px 20px;
          position: relative;
      }

      /* Водяной знак: один полностраничный инлайн-SVG. Поворот строк сделан ВНУТРИ
         SVG (вектор), без CSS-transform — поэтому текст чёткий, без растрового мыла. */
      .watermark {
          position: fixed;
          top: 0; left: 0;
          width: 100%; height: 100%;
          z-index: 0;
          pointer-events: none;
      }

      table.layout, .header-left, .header-right, .inner, .company-block, .director-block{
          position: relative;
          z-index: 1;
      }

      h1,h2,h3,h4,h5,h6 { margin: 0; padding: 0; }

      .b       { font-weight: bold; }
      .center  { text-align: center; }
      .mt-5    { margin-top: 5px; }
      .mt-10   { margin-top: 10px; }
      .mt-15   { margin-top: 15px; }
      .mt-20   { margin-top: 20px; }

      /* две колонки на странице */
      table.layout {
          width: 100%;
          border-collapse: collapse;
      }

      td.col {
          width: 50%;
          vertical-align: top;
          padding: 0 10px;
      }

      /* --- левый заголовок (RU) --- */
      .header-left {
          text-align: center;
          line-height: 1.25;
          margin-bottom: 6px;
      }
      .header-left .title { font-weight: bold; font-size: 15px; }
      .header-left .sub   { font-weight: bold; font-size: 12px; }
      .header-left .subi  { font-style: italic; font-size: 11px; }

      /* --- правый заголовок (EN) с логотипом --- */
      .header-right { width: 100%; border-collapse: collapse; margin-bottom: 8px; }
      .header-right td { vertical-align: middle; }
      .header-right .logo-cell { width: 120px; text-align: center; }
      .header-right .titles { text-align: center; font-weight: bold; font-size: 14px; line-height: 1.4; }
      .logo-img { height: 80px; }

      /* --- таблицы --- */
      table.inner {
          width: 100%;
          border-collapse: collapse;
          border: 1px solid #000;
      }
      table.inner td {
          border: 1px solid #000;
          padding: 3px 5px;
          vertical-align: top;
          font-size: 12px;
      }
      /* Белый фон только на ячейках-названиях — водяной знак под ними не просвечивает.
         Ячейки со значениями остаются прозрачными (вотермарк виден). */
      td.lbl, td.lbl-en { background: #fff; }
      .lbl .ru { font-weight: bold; }
      .lbl .en { font-style: italic; }
      .lbl-en { font-size: 12px; }

      .paid { font-weight: bold; font-size: 14px; margin: 9px 0 5px; }

      .company-block { line-height: 1.35; font-size: 12px; }

      .director-block {
          position: relative;
          height: 44mm;
          font-size: 14px;
      }
      /* Печать ООО — стандартный диаметр круга 40 мм. В исходных PNG круг
         занимает всю высоту картинки, поэтому height изображения = диаметру.
         scale в PdfRenderer = 1.0, значит 40mm печатается ровно 40 мм. */
      .stamp-img { position: absolute; height: 40mm; opacity: 1; }
      .qr-img { height: 110px; }
  </style>
</head>
<body>
<%
  invitation_number = @invitation.current_id
  reference_number  = "04845639"

  sex_text_ru =
    case @invitation.sex.to_s.downcase
    when "1", "male", "м", "муж", "m" then "Мужской"
    when "0", "female", "ж", "жен", "f" then "Женский"
    else ""
    end

  hotels_ru = (@invitation.try(:hotels_ru) || @invitation.hotels || "").to_s
  hotels_ru_html = hotels_ru.gsub(/\r\n|\r|\n/, "<br>").html_safe
  hotels_en = (@invitation.hotels || "").to_s
  hotels_en_html = hotels_en.gsub(/\r\n|\r|\n/, "<br>").html_safe

  city_ru = @invitation.cities.to_s.presence || "MOSCOW"
  city_en = (@invitation.respond_to?(:cities_en) && @invitation.cities_en.present?) ? @invitation.cities_en : city_ru

  arrival_date   = @invitation.arival_date
  departure_date = @invitation.departure_date
  birth_date     = @invitation.birthDate

  print_date =
    if @invitation.respond_to?(:issued_on) && @invitation.issued_on.present?
      @invitation.issued_on
    else
      @invitation.created_at.to_date rescue Date.today
    end
  print_date_str = print_date.strftime('%d.%m.%Y')

  full_name = [@invitation.surname, @invitation.name, @invitation.middlename].reject(&:blank?).join(" ")
  curr_name_package = get_name_package(@invitation.package.to_sym)

  # Две чередующиеся строки водяного знака (как в рефе): имя+номер и фраза о защите.
  wm_name = "#{@invitation.surname} #{@invitation.name} #{invitation_number}".strip
  wm_note = "Protected against copying"

  # Параметры (все в одном месте):
  wm_vb_w  = 1123        # ширина холста (A4 landscape @96dpi)
  wm_vb_h  = 794         # высота холста
  wm_angle = -30         # наклон строк
  wm_font  = 14          # размер шрифта
  wm_fill  = "#777777"   # цвет
  wm_op    = "0.20"      # насыщенность
  wm_gap   = 34          # расстояние между строками (меньше -> плотнее)

  esc = ->(s) { ERB::Util.html_escape(s) }
  # одна строка = фраза, повторённая на всю ширину диагонали
  unit_name = ("#{esc.call(wm_name)}&#160;&#160;&#160;&#160;" * 12)
  unit_note = ("#{esc.call(wm_note)}&#160;&#160;&#160;&#160;" * 12)

  wm_rows = []
  i = 0
  y = -300
  while y < wm_vb_h + 300
    txt = i.even? ? unit_name : unit_note
    x   = i.even? ? -400 : -470   # кирпичный сдвиг чётных/нечётных
    wm_rows << %(<text x="#{x}" y="#{y}" xml:space="preserve" font-family="DejaVu Sans, Arial, sans-serif" font-size="#{wm_font}" font-weight="400" fill="#{wm_fill}" fill-opacity="#{wm_op}">#{txt}</text>)
    y += wm_gap
    i += 1
  end
  wm_svg_inner = wm_rows.join.html_safe
%>

<svg class="watermark" viewBox="0 0 <%= wm_vb_w %> <%= wm_vb_h %>" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
  <g transform="rotate(<%= wm_angle %> <%= wm_vb_w / 2 %> <%= wm_vb_h / 2 %>)"><%= wm_svg_inner %></g>
</svg>

<table class="layout">
  <tr>
    <!-- ЛЕВАЯ КОЛОНКА: ПОДТВЕРЖДЕНИЕ (RU) -->
    <td class="col left">
      <div class="header-left">
        <span class="title">ПОДТВЕРЖДЕНИЕ № <%= invitation_number %></span><br>
        <span class="sub">о приеме иностранного туриста</span><br>
        <span class="subi">(tourist confirmation)</span>
      </div>

      <table class="inner">
        <tr>
          <td class="lbl" style="width: 27%"><span class="ru">Кратность визы</span><br><span class="en">(number of entries)</span></td>
          <td style="width: 23%"><%= curr_name_package %></td>
          <td class="lbl" style="width: 27%"><span class="ru">Гражданство</span><br><span class="en">(citizenship)</span></td>
          <td style="width: 23%"><%= @invitation.citizenship_title(lang: :ru) %></td>
        </tr>
        <tr>
          <td class="lbl"><span class="ru">Въезд с</span><br><span class="en">(date of arrival)</span></td>
          <td><%= arrival_date %></td>
          <td class="lbl"><span class="ru">Выезд до</span> <span class="en">(date of departure)</span></td>
          <td><%= departure_date %></td>
        </tr>
        <tr>
          <td class="lbl"><span class="ru">Фамилия/Имя</span><br><span class="en">(surname/name)</span></td>
          <td colspan="3"><%= full_name %></td>
        </tr>
        <tr>
          <td class="lbl"><span class="ru">Дата рождения</span><br><span class="en">(date of birth)</span></td>
          <td><%= birth_date %></td>
          <td class="lbl"><span class="ru">Пол</span><br><span class="en">(sex)</span></td>
          <td><%= sex_text_ru %></td>
        </tr>
        <tr>
          <td class="lbl"><span class="ru">№ паспорта</span><br><span class="en">(passport №)</span></td>
          <td><%= @invitation.passport %></td>
          <td class="lbl"><span class="ru">Цель</span><br><span class="en">(purpouse of visit)</span></td>
          <td>Туризм</td>
        </tr>
        <tr>
          <td class="lbl"><span class="ru">Маршрут и места размещения</span><br><span class="en">(route and hotel)</span></td>
          <td colspan="3"><%= hotels_ru_html %></td>
        </tr>
      </table>

      <div class="paid">Тур оплачен полностью</div>

      <div class="company-block">
        Дополнительные сведения: индивидуальный тур<%= ". #{@invitation.additional_info.to_s.strip}" if @invitation.additional_info.present? %><br>
        <span class="b">Принимающая организация, ее адрес:</span><br>
        ООО "ФОРТУНА ТРЕВЕЛ",<br>
        360030, РОССИЯ, КАБАРДИНО-БАЛКАРСКАЯ РЕСП, НАЛЬЧИК Г.О., Г. НАЛЬЧИК,<br>
        ПР-КТ КУЛИЕВА, Д. 19А, КВ. 2.<br>
        Тел.: +7 965 396 96 00<br>
        E-mail: manager.fortunatravel@gmail.com<br>
        ИНН 0700030427<br>
        Реестровый (референс) номер: <%= reference_number %><br>
        Дата: <%= print_date_str %>
      </div>

      <div class="director-block">
        <div style="margin-top: 12px;">Генеральный директор&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Ахматова И.В.</div>
        <img src="data:image/png;base64,<%= @seal_ru_base64 %>" class="stamp-img" style="left: 150px; top: 20px;">
      </div>
    </td>

    <!-- ПРАВАЯ КОЛОНКА: VOUCHER & CONFIRMATION (EN) -->
    <td class="col right">
      <table class="header-right">
        <tr>
          <td class="logo-cell">
            <img src="data:image/png;base64,<%= @logo_base64 %>" class="logo-img">
          </td>
          <td class="titles">
            ООО «ФОРТУНА ТРЕВЕЛ»<br>
            Fortuna travel LLC<br>
            Reference No.: <%= reference_number %><br>
            VOUCHER &amp; CONFIRMATION<br>
            No. <%= invitation_number %>
          </td>
        </tr>
      </table>

      <table class="inner">
        <tr>
          <td class="lbl-en" style="width: 27%">Country / city</td>
          <td colspan="3">Russia: <%= city_en %></td>
        </tr>
        <tr>
          <td class="lbl-en">Hotel(s)</td>
          <td colspan="3"><%= hotels_en_html %></td>
        </tr>
        <tr>
          <td class="lbl-en">Names</td>
          <td colspan="3"><%= full_name %></td>
        </tr>
        <tr>
          <td class="lbl-en">Check in</td>
          <td style="width: 23%"><%= arrival_date %></td>
          <td class="lbl-en" style="width: 27%">Check out</td>
          <td style="width: 23%"><%= departure_date %></td>
        </tr>
        <tr>
          <td class="lbl-en">Accommodation</td>
          <td><%= @invitation.accomodation %></td>
          <td class="lbl-en">Meals</td>
          <td><%= @invitation.meals %></td>
        </tr>
      </table>

      <div class="paid">FULLY PAID</div>

      <table style="width: 100%; border-collapse: collapse;">
        <tr>
          <td style="vertical-align: top;">
            <div class="company-block">
              <span class="b">Receiving Company:</span><br>
              Reference number: <%= reference_number %><br>
              Fortuna travel LLC<br>
              360030, Russia, Kabardino-Balkarian Republic, Nalchik Urban<br>
              District, Nalchik, 19A Kulieva Avenue, Apt. 2<br>
              Tel: +7 965 396 96 00<br>
              E-mail: manager.fortunatravel@gmail.com<br>
              TIN: 0700030427<br>
              Date: <%= print_date_str %>
            </div>
          </td>
          <td style="vertical-align: top; text-align: right; width: 120px;">
            <img src="data:image/png;base64,<%= @qr_base64 %>" class="qr-img">
          </td>
        </tr>
      </table>

      <div class="director-block">
        <div style="margin-top: 6px;">General Director:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;/Irina Ahmatova/</div>
        <img src="data:image/png;base64,<%= @seal_en_base64 %>" class="stamp-img" style="left: 120px; top: 12px;">
      </div>
    </td>
  </tr>
</table>
</body>
</html>